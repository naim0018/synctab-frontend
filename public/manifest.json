{
  "manifest_version": 3,
  "name": "SyncTab - Sleek Office Dashboard",
  "version": "1.0.0",
  "description": "Collaborative, premium new-tab dashboard for office workers to sync notes, tasks, bookmarks, and chat.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "bookmarks",
    "tabs",
    "topSites",
    "sessions"
  ],
  "host_permissions": [
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://localhost/*", "*://127.0.0.1/*"],
      "js": ["content.js"]
    }
  ]
}
